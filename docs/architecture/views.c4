views {

  // ── Level 1: System Landscape ────────────────────────────────────────────

  view index {
    title 'Botashka — System Landscape'
    include *
    style developer {
      color sky
    }
  }

  // ── Level 2: System Context ───────────────────────────────────────────────

  view context of botashka {
    title 'Botashka — System Context'
    include botashka
    include developer
    include anthropic
    include nreplClient
    include filesystem
    include developer -> botashka
    include botashka -> anthropic
    include botashka -> filesystem
    include nreplClient -> botashka
  }

  // ── Level 3: Containers ───────────────────────────────────────────────────

  view containers of botashka {
    title 'Botashka — Containers'
    include botashka.*
    include developer -> botashka.repl
    include anthropic
    include filesystem
    include nreplClient -> botashka.repl
    include botashka.llmClient -> anthropic
    include botashka.core -> filesystem
    include botashka.builtins -> filesystem
    include botashka.sessionTrace -> filesystem

    style botashka.sessionTrace {
      color secondary
    }
    style botashka.builtins {
      color amber
    }
  }

  // ── Agent Core detail ────────────────────────────────────────────────────

  view agentCore {
    title 'Botashka — Agent Core (ReAct + Context + Built-ins)'
    include botashka.core
    include botashka.planner
    include botashka.todoClj
    include botashka.react
    include botashka.llmContext
    include botashka.specValidator
    include botashka.llmClient
    include botashka.sessionTrace
    include botashka.toolLibrary
    include botashka.executor
    include botashka.builtins
    include anthropic

    include botashka.core -> botashka.planner
    include botashka.core -> botashka.react
    include botashka.core -> botashka.sessionTrace
    include botashka.core -> botashka.todoClj
    include botashka.todoClj -> botashka.sessionTrace
    include botashka.planner -> botashka.llmContext
    include botashka.planner -> botashka.llmClient
    include botashka.planner -> botashka.sessionTrace
    include botashka.react -> botashka.llmContext
    include botashka.react -> botashka.llmClient
    include botashka.react -> botashka.specValidator
    include botashka.react -> botashka.toolLibrary
    include botashka.react -> botashka.executor
    include botashka.react -> botashka.sessionTrace
    include botashka.llmContext -> botashka.sessionTrace
    include botashka.specValidator -> botashka.toolLibrary
    include botashka.executor -> botashka.toolLibrary
    include botashka.executor -> botashka.builtins
    include botashka.builtins -> botashka.toolLibrary
    include botashka.builtins -> botashka.sessionTrace
    include botashka.builtins -> botashka.llmClient
    include botashka.llmClient -> anthropic
  }

  // ── Dynamic: ReAct Loop (generated tool path) ────────────────────────────

  dynamic view reactLoop {
    title 'Botashka — ReAct Loop: Generated Tool Path'

    botashka.core -> botashka.react 'react-step!(task-doc, session-trace)'
    botashka.react -> botashka.llmContext 'llm-context(trace, :think)'
    botashka.llmContext -> botashka.sessionTrace 'select-events :think'
    botashka.react -> botashka.llmClient 'complete(think-payload)'
    botashka.llmClient -> anthropic 'POST /v1/messages'
    anthropic -> botashka.llmClient 'SSE: :generate decision'
    botashka.react -> botashka.llmContext 'llm-context(trace, :generate)'
    botashka.react -> botashka.llmClient 'complete(generate-payload)'
    anthropic -> botashka.llmClient 'SSE: .clj source code'
    botashka.react -> botashka.specValidator 'validate-tool-source(code)'
    botashka.specValidator -> botashka.toolLibrary 'isolated SCI eval'
    botashka.react -> botashka.toolLibrary 'save-tool! + update index'
    botashka.react -> botashka.executor 'execute-tool(tool-path, args)'
    botashka.executor -> botashka.toolLibrary 'bb -f tools/<name>.clj'
    botashka.executor -> botashka.react 'return {:status :stdout}'
    botashka.react -> botashka.sessionTrace 'append :observe(result)'
    botashka.react -> botashka.core 'return result'
    botashka.core -> botashka.repl 'emit!(:assistant-out)'
  }

  // ── Dynamic: ReAct Loop (built-in tool path with confirmation) ───────────

  dynamic view reactLoopBuiltin {
    title 'Botashka — ReAct Loop: Built-in Tool Path (with confirmation)'

    botashka.core -> botashka.react 'react-step!(task-doc, session-trace)'
    botashka.react -> botashka.llmContext 'llm-context(trace, :think)'
    botashka.llmContext -> botashka.sessionTrace 'select-events :think + tool-index'
    botashka.react -> botashka.llmClient 'complete(think-payload)'
    botashka.llmClient -> anthropic 'POST /v1/messages'
    anthropic -> botashka.llmClient 'SSE: :reuse :shell decision'
    botashka.react -> botashka.executor 'execute-tool(:shell, args)'
    botashka.executor -> botashka.repl 'emit! :ask "Run shell: rm …? [y/n]"'
    botashka.repl -> developer 'displays confirmation prompt'
    developer -> botashka.repl 'y — approved'
    botashka.repl -> botashka.executor 'approved'
    botashka.executor -> botashka.builtins 'dispatch :shell fn'
    botashka.builtins -> botashka.executor 'return {:stdout :stderr :exit}'
    botashka.executor -> botashka.react 'return {:status :ok :result stdout}'
    botashka.react -> botashka.sessionTrace 'append :observe(result)'
    botashka.react -> botashka.core 'return result'
    botashka.core -> botashka.repl 'emit!(:assistant-out)'
  }

  // ── Dynamic: Goal → Plan → Execute ───────────────────────────────────────

  dynamic view planningFlow {
    title 'Botashka — Goal to Execution Flow'

    developer -> botashka.repl 'types goal + @file refs'
    botashka.repl -> botashka.core 'start! read-line'
    botashka.core -> filesystem 'read @path file contents'
    filesystem -> botashka.core 'file content'
    botashka.core -> botashka.sessionTrace 'append :file-context + :user-input'
    botashka.core -> botashka.planner 'plan!(goal, ctx)'
    botashka.planner -> botashka.llmContext 'llm-context(trace, :plan)'
    botashka.planner -> botashka.llmClient 'complete(plan-payload)'
    botashka.llmClient -> anthropic 'POST /v1/messages'
    anthropic -> botashka.llmClient 'EDN tasks list'
    botashka.planner -> botashka.sessionTrace 'append :todo event'
    botashka.planner -> botashka.core 'return tasks'
    botashka.core -> botashka.todoClj 'current-todo + topo-sort'
    botashka.core -[writes]-> botashka.bbEdn 'publish-bb-edn! (derived from :todo)'
    botashka.core -> botashka.react 'react-step! per task'
    botashka.core -> botashka.repl 'emit!(answer)'
  }

  // ── Dynamic: Plan Mutation ────────────────────────────────────────────────

  dynamic view planMutation {
    title 'Botashka — Plan Mutation (:plan-amend)'

    botashka.react -> botashka.executor 'execute-tool(fetch-url, args)'
    botashka.executor -> botashka.toolLibrary 'bb -f tools/fetch-url.clj'
    botashka.executor -> botashka.react 'return {:status :error "404"}'
    botashka.react -> botashka.sessionTrace 'append :observe(error)'
    botashka.react -> botashka.core 'return {:status :error}'
    botashka.core -> botashka.planner 'plan-amend!(ctx, reason, old-task-names)'
    botashka.planner -> botashka.sessionTrace 'append :plan-amend + :todo (before LLM call)'
    botashka.planner -> botashka.llmContext 'llm-context(amend-trace, :plan)'
    botashka.planner -> botashka.llmClient 'complete(revised-plan-ctx)'
    botashka.llmClient -> anthropic 'POST /v1/messages'
    anthropic -> botashka.llmClient 'EDN revised tasks list'
    botashka.planner -> botashka.core 'return revised tasks'
    botashka.core -> botashka.todoClj 'current-todo + topo-sort'
    botashka.core -[writes]-> botashka.bbEdn 'publish-bb-edn! (derived from new :todo)'
    botashka.core -> botashka.react 'react-step! with new task'
  }
}
