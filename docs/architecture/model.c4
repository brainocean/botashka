model {

  actor developer 'Developer' {
    description 'Local developer running Botashka in a Babashka REPL'
  }

  system botashka 'Botashka' {
    description 'Local Clojure-native agentic assistant. Uses generated code snippets as its action space (CodeAct style). Self-growing tool library, hybrid plan+ReAct loop.'
    technology 'Babashka / SCI / Clojure'

    container repl 'REPL Interface' {
      description 'V1: bb repl + start! read-line loop. V2: bb nrepl-server — any nREPL client connects and receives output as :out messages. Receives emit! output and :ask confirmation events.'
      technology 'Babashka REPL / nREPL'
      style {
        shape browser
        color sky
      }
    }

    container core 'core.clj' {
      description 'start! loop, emit! output seam, format-event, run-goal! (topo-sort + task iteration), @path file parsing. Reads filesystem for @path tokens. Derives task :status from trace.'
      technology 'Clojure / Babashka'
      style {
        color primary
      }
    }

    container planner 'planner.clj' {
      description 'Decomposes user goal into ordered steps via LLM. Appends :todo event to session-trace. plan-amend! handles structural replanning: appends :plan-amend + new :todo event to session-trace.'
      technology 'Clojure / Babashka'
      style {
        color green
      }
    }

    container react 'react.clj' {
      description 'ReAct loop: THINK → GENERATE+VALIDATE → EXECUTE → OBSERVE. Dispatches to executor for generated tools or builtins for built-in tools. run-tasks! executes in-memory EDN task maps for subagents.'
      technology 'Clojure / Babashka'
      style {
        color green
      }
    }

    container llmContext 'llm_context.clj' {
      description 'Pure context assembly. select-events filters session-trace per LLM call type (:plan/:think/:generate). truncate-content caps :file-context at 8k and :observe at 4k chars. render-trace formats events. system-prompt constants per call type. Returns {:system :messages} map.'
      technology 'Clojure / Babashka'
      style {
        color amber
      }
    }

    container specValidator 'spec.clj' {
      description 'Validates generated tool source before execution. Syntactically checks for s/def or s/fdef via regex, then evaluates with sci/eval-string (clojure.spec.alpha is natively available in Babashka SCI). Generated tools only — built-ins bypass this gate.'
      technology 'Clojure / SCI / clojure.spec.alpha'
      style {
        color red
      }
    }

    container llmClient 'llm.clj' {
      description 'Claude API client. Non-streaming complete (v1) wrapping SSE stream. stream-chat stubbed for v2 token streaming.'
      technology 'Clojure / babashka.http-client / SSE'
      style {
        color slate
      }
    }

    container sessionTrace 'session-trace' {
      description 'Append-only vector of typed event maps: :file-context :user-input :todo :todo-update :plan-amend :think :reuse :generate :validate :execute :observe :assistant-out :ask :error. Single source of truth for task-status, todo state, context assembly, and replay. Written to sessions/<id>.edn incrementally.'
      technology 'Clojure atom (in-memory) + EDN (on-disk)'
      style {
        shape cylinder
        color secondary
      }
    }

    container todoClj 'todo.clj' {
      description 'Pure todo state derivation. current-todo: derives live task list from last :todo event merged with subsequent :todo-update events. task-status: derives :open/:in-progress/:finished/:error per task. topo-sort: topological ordering of tasks by :depends vectors for run-goal! iteration.'
      technology 'Clojure / Babashka'
      style {
        color green
      }
    }

    container toolLibrary 'Tool Library + Index' {
      description 'tool-index.edn: registry of all tools (built-ins with :builtin true + generated). LLM reads this index on every :think call to decide reuse/generate. tools/*.clj: generated Clojure snippets, each with ns form + clojure.spec defs + single defn. Promoted across sessions via git commit.'
      technology 'tool-index.edn + Clojure .clj files'
      style {
        shape cylinder
        color green
      }
    }

    container builtins 'builtins.clj' {
      description 'Built-in tool dispatch — direct fn calls, no subprocess, no spec validation. Registry: read-file, write-file, list-dir, shell (:confirm true), todo-update, session-trace, task-status, tool-index, save-tool, llm-complete (:confirm true). :confirm true tools emit :ask event and await human y/n before executing.'
      technology 'Clojure / Babashka'
      style {
        color amber
      }
    }

    container executor 'Executor' {
      description 'Routes execution: generated tools → bb -f tools/<name>.clj subprocess (args EDN-encoded on command line; falls back to clojure -M on SCI limits). Built-in tools → builtins.clj direct fn dispatch. Checks :confirm true flag — emits :ask event and awaits human approval before proceeding. Returns {:status :stdout :stderr} to react.'
      technology 'Babashka subprocess / clojure -M'
      style {
        color muted
      }
    }
  }

  system anthropic 'Anthropic API' {
    #external
    description 'Claude claude-sonnet-4-5. Used for planning decomposition (:plan), ReAct reasoning (:think), and code generation (:generate).'
    technology 'HTTPS / SSE'
    style {
      color amber
    }
  }

  system filesystem 'Local Filesystem' {
    #external
    description 'Local disk: source files read via @path syntax, tools/*.clj, tool-index.edn, sessions/*.edn persistence.'
    technology 'POSIX filesystem'
    style {
      shape storage
      color muted
    }
  }

  system nreplClient 'nREPL Client' {
    #external
    description 'V2/V3: any nREPL client — CIDER, Calva, vim-iced, custom TUI, Telegram bot. Connects to bb nrepl-server, receives :out messages.'
    technology 'nREPL protocol'
    style {
      shape browser
      color muted
    }
  }

  // --- Relationships ---

  developer -> botashka.repl 'types goal / @file refs'
  developer -> botashka.repl 'approves/denies :ask confirmation'
  botashka.repl -> botashka.core 'calls start!'

  botashka.core -[reads]-> filesystem '@path file reads'
  botashka.core -> botashka.sessionTrace 'append-event!'
  botashka.core -> botashka.planner 'plan!(goal, ctx)'
  botashka.core -> botashka.react 'react-step!(task, ctx)'
  botashka.core -> botashka.todoClj 'current-todo + topo-sort'
  botashka.core -[emits]-> botashka.repl 'emit!(event) including :ask for confirmations'

  botashka.planner -> botashka.llmContext 'llm-context(trace, :plan)'
  botashka.planner -> botashka.llmClient 'complete(messages, api-key)'
  botashka.planner -[reads]-> botashka.sessionTrace 'context assembly input'
  botashka.planner -[writes]-> botashka.sessionTrace 'append :todo (initial + replan) + :plan-amend'

  botashka.todoClj -[reads]-> botashka.sessionTrace 'derive current-todo from :todo + :todo-update events'

  botashka.react -> botashka.llmContext 'llm-context(trace, :think/:generate)'
  botashka.react -> botashka.llmClient 'complete(messages, api-key)'
  botashka.react -[validates]-> botashka.specValidator 'validate-tool-source(generated code only)'
  botashka.react -> botashka.toolLibrary 'read tool-index / save-tool!'
  botashka.react -> botashka.executor 'execute-tool(code/name, args)'
  botashka.react -[reads]-> botashka.sessionTrace 'context assembly input'
  botashka.react -[writes]-> botashka.sessionTrace 'append :think/:generate/:validate/:execute/:observe'

  botashka.llmContext -[reads]-> botashka.sessionTrace 'select-events + render-trace'

  botashka.specValidator -[validates]-> botashka.toolLibrary 'isolated SCI eval (generated tools only)'
  botashka.executor -[executes]-> botashka.toolLibrary 'bb -f subprocess (generated tools)'
  botashka.executor -> botashka.builtins 'direct fn dispatch (built-in tools)'
  botashka.executor -[emits]-> botashka.repl 'emit! :ask → await y/n (confirm true tools)'

  botashka.builtins -[reads]-> filesystem 'read-file, list-dir'
  botashka.builtins -[writes]-> filesystem 'write-file, save-tool'
  botashka.builtins -[reads]-> botashka.sessionTrace 'session-trace built-in'
  botashka.builtins -[writes]-> botashka.sessionTrace 'todo-update built-in appends :todo-update event'
  botashka.builtins -> botashka.toolLibrary 'tool-index, save-tool built-ins'
  botashka.builtins -[calls]-> botashka.llmClient 'llm-complete built-in'

  botashka.llmClient -[calls]-> anthropic 'POST /v1/messages (SSE)'

  botashka.sessionTrace -[writes]-> filesystem 'append sessions/<id>.edn incrementally'

  nreplClient -> botashka.repl 'nREPL :eval — V2+'
}
